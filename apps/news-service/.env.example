# Server Configuration
PORT=4003
APP_NAME=news-service

# Database Configuration
DATABASE_TYPE=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5435
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_DB_NAME=news_db
DATABASE_SYNCHRONIZE=true

# API Keys
CRYPTOCOMPARE_API_KEY=your_cryptocompare_api_key_here

# AWS Configuration for EventBridge Scheduler & SQS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# AWS SQS & EventBridge
SQS_IMPACT_QUEUE_ARN=arn:aws:sqs:us-east-1:123456789012:impact-queue
SQS_SENTIMENT_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/news-sentiment-queue
EVENTBRIDGE_ROLE_ARN=arn:aws:iam::123456789012:role/EventBridgeSchedulerRole
