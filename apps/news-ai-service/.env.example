# Server Configuration
PORT=4004
APP_NAME=news-ai-service

# Database Configuration (Same DB as news-service)
DATABASE_TYPE=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5435
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_DB_NAME=news_db
DATABASE_SYNCHRONIZE=true

# AWS Configuration
AWS_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# AWS SQS Configuration
SQS_SENTIMENT_QUEUE_URL=https://sqs.ap-southeast-2.amazonaws.com/123456789012/news-sentiment-queue
SQS_IMPACT_QUEUE_URL=https://sqs.ap-southeast-2.amazonaws.com/123456789012/news-impact-queue
SQS_MAX_MESSAGES=10
SQS_WAIT_TIME_SECONDS=20
SQS_VISIBILITY_TIMEOUT=30

# AWS S3 Configuration
S3_TRAINING_BUCKET=crypto-news-datalake-training

# Training Data Upload
TRAINING_UPLOAD_ENABLED=false

# Sentiment Analysis
SENTIMENT_MODEL=vader
SENTIMENT_ENABLED=true

# Market Service (for RPC communication)
MARKET_SERVICE_TRANSPORT=0
MARKET_SERVICE_HOST=localhost
MARKET_SERVICE_PORT=8004
